---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getSlug, findRelatedPosts } from '../../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];

  for (const post of posts) {
    const locale = post.data.postLang || 'en';
    if (locale !== 'zh-CN' && locale !== 'bilingual') continue;
    const slug = getSlug(post);
    paths.push({
      params: { locale: 'zh-CN', slug },
      props: { post },
    });
  }

  return paths;
}

type Props = {
  post: any;
};

const currentLocale = 'zh-CN';
const post = Astro.props.post;
const { Content } = await render(post);
const slug = getSlug(post);
const allPosts = await getCollection('blog');
const related = findRelatedPosts(post, allPosts);

// Count words: CJK characters count as 1 word each, spaces separate English words
const body = post.body || '';
const cjkChars = (body.match(/[\u4e00-\u9fff\u3400-\u4dbf]/g) || []).length;
const englishWords = body.replace(/[\u4e00-\u9fff\u3400-\u4dbf]/g, '').split(/\s+/).filter(Boolean).length;
const wordCount = cjkChars + englishWords;
---

<BlogPost {...post.data} locale={currentLocale} template={post.data.template} slug={slug} wordCount={wordCount} relatedPosts={related}>
  <Content />
</BlogPost>

<script is:inline define:vars={{ slug }}>
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      await fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug })
      });
    } catch (e) {
      console.error('Failed to record view:', e);
    }
  });
</script>
