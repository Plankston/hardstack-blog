---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { useTranslations } from '../../i18n/ui';
import { getSlug } from '../../i18n/utils';

const currentLocale = 'en';
const t = useTranslations(currentLocale);

const posts = (await getCollection('blog'))
  .filter((p) => (p.data.postLang || 'en') === currentLocale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function categoryPillClass(cat: string | undefined): string {
  if (!cat) return 'category-pill-default';
  const c = cat.toLowerCase();
  if (c === 'ai-tools') return 'category-pill-ai-tools';
  if (c === 'guide') return 'category-pill-guide';
  if (c === 'review') return 'category-pill-review';
  return 'category-pill-default';
}

function categoryLabel(cat: string | undefined): string {
  if (!cat) return 'Uncategorized';
  return cat.toLowerCase().replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead title={`${t('blog.allPosts')} — ${t('site.title')}`} description={t('site.description')} locale={currentLocale} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--bg-card)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--text-body)] focus:shadow-lg focus:outline-none">
      Skip to content
    </a>
    <Header locale={currentLocale} />
    <main id="main-content">
      <section class="section-inner">
        <div class="mx-auto" style="max-width:960px">
          <h1 class="font-['Playfair_Display'] text-3xl font-bold text-[var(--text-heading)]">{t('blog.allPosts')}</h1>
          <p class="mt-2 text-sm text-[var(--text-muted)]">
            {posts.length} articles total
          </p>
        </div>
      </section>

      <section class="section-inner pt-0">
        <div class="mx-auto" style="max-width:960px">
          {posts.length > 0 ? (
            <div class="flex flex-col gap-3" id="archive-list">
              {posts.map((post, i) => (
                <a
                  href={new URL(`/blog/${getSlug(post)}/`, Astro.site).pathname}
                  class="article-card no-underline reveal"
                  style={`transition-delay: ${i * 60}ms; animation-delay: ${i * 60}ms`}
                >
                  <div class="article-card-content">
                    <div class="mb-1.5 flex flex-wrap items-center gap-2">
                      <span class="post-meta text-[10px]">
                        <FormattedDate date={post.data.pubDate} locale={currentLocale} />
                      </span>
                      {post.data.category && (
                        <span class={`${categoryPillClass(post.data.category)} article-card-category`}>
                          {categoryLabel(post.data.category)}
                        </span>
                      )}
                      {post.data.difficulty && (
                        <span class="text-[10px] uppercase tracking-wider text-[var(--text-faint)]">[{post.data.difficulty}]</span>
                      )}
                      {post.data.timeToRead && (
                        <span class="text-[10px] text-[var(--text-faint)]">· {post.data.timeToRead} {t('blog.minRead')}</span>
                      )}
                    </div>
                    <h2 class="text-base font-semibold leading-snug text-[var(--text-heading)] truncate">
                      {post.data.title}
                    </h2>
                    <p class="text-sm leading-relaxed text-[var(--text-muted)] line-clamp-2">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="py-16 text-center text-[var(--text-faint)]">
              <p class="font-serif text-lg italic">No posts yet.</p>
            </div>
          )}
        </div>
      </section>
    </main>
    <Footer locale={currentLocale} />
  </body>
</html>

<script>
  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    }
  }, { rootMargin: '40px' });

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
