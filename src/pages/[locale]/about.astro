---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { useTranslations, LOCALES } from '../../i18n/ui';
import { getLocaleFromParams } from '../../i18n/utils';

export async function getStaticPaths() {
  return Object.keys(LOCALES).map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const currentLocale = getLocaleFromParams(locale);
const t = useTranslations(currentLocale);
---

<!doctype html>
<html lang={t('site.lang')}>
  <head>
    <BaseHead title={`${t('about.title')} — ${t('site.title')}`} description={t('about.description')} />
  </head>
  <body>
    <Header locale={currentLocale} />
    <main>
      <article>
        <header class="mb-10">
          <p class="post-meta mb-2">{t('nav.about')}</p>
          <h1 class="font-serif text-3xl">{t('about.title')}</h1>
        </header>
        <hr class="mb-10" />
        <div class="prose">
          {currentLocale === 'en' ? (
            <>
              <p class="text-lg leading-relaxed text-[var(--color-ink-light)]">
                <strong class="text-[var(--color-ink)]">HardStack</strong> is a technical blog focused
                on open-source, self-hosted, and AI tool projects.
              </p>
              <p>
                Every open-source project deserves a proper setup. No armchair reviews here — only real
                installation logs, annotated error screenshots, and honest comparisons.
              </p>

              <h2>Our Promise</h2>
              <ol>
                <li><strong>Hands-on verified</strong> — not armchair reviews</li>
                <li><strong>Real error screenshots</strong> — not flawless tutorials</li>
                <li><strong>Follow-up after 3 months</strong> — not publish-and-forget</li>
                <li><strong>Honest comparisons</strong> — "I recommend X over Y because…"</li>
                <li><strong>SEO-friendly</strong> — indexed and searchable</li>
              </ol>

              <h2>Content Categories</h2>
              <ul>
                <li>Installation Guides (50%) — 5k–10k word deep dives</li>
                <li>Comparisons (20%) — high-search-volume X vs Y</li>
                <li>Troubleshooting (15%) — real errors with solutions</li>
                <li>News & Analysis (10%) — stories behind the projects</li>
                <li>Best-of Lists (5%) — annual self-hosted awards</li>
              </ul>

              <h2>About the Author</h2>
              <p>
                A full-stack developer who loves open-source, self-hosting, and AI tools. Believes
                that good content deserves to be taken seriously — a single well-written guide can
                save someone 10 hours.
              </p>
            </>
          ) : (
            <>
              <p class="text-lg leading-relaxed text-[var(--color-ink-light)]">
                <strong class="text-[var(--color-ink)]">HardStack</strong> 是一个专注开源、自托管
                与 AI 工具类项目的深度技术博客。
              </p>
              <p>
                每个开源项目都值得被认真装一遍。这里没有云测评，只有亲自装过、踩过坑、
                拍过截图的真实记录。
              </p>

              <h2>我们承诺</h2>
              <ol>
                <li><strong>亲自装过</strong> — 不是云测评</li>
                <li><strong>真实报错截图</strong> — 不是完美教程</li>
                <li><strong>3 个月后回访更新</strong> — 不是发完就忘</li>
                <li><strong>有对比有推荐</strong> — "X vs Y 我推荐 X，因为…"</li>
                <li><strong>可被搜索引擎搜到</strong> — SEO 友好</li>
              </ol>

              <h2>内容方向</h2>
              <ul>
                <li>安装教程（50%）— 完整 5000-10000 字深度指南</li>
                <li>横向对比（20%）— X vs Y 类高搜索量内容</li>
                <li>踩坑合集（15%）— 真实报错与解决方案</li>
                <li>新闻解读（10%）— 开源项目背后的故事</li>
                <li>盘点榜单（5%）— 年度最佳自托管项目</li>
              </ul>

              <h2>关于作者</h2>
              <p>
                热爱开源、自托管和 AI 工具的全栈开发者。相信好内容值得被认真对待，
                一篇好教程能帮人省 10 个小时。
              </p>
            </>
          )}
        </div>
      </article>
    </main>
    <Footer locale={currentLocale} />
  </body>
</html>
