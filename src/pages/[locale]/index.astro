---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { useTranslations, LOCALES } from '../../i18n/ui';
import { getLocaleFromParams, getSlug } from '../../i18n/utils';

export async function getStaticPaths() {
  return Object.keys(LOCALES).map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const currentLocale = getLocaleFromParams(locale);
const t = useTranslations(currentLocale);

const posts = (await getCollection('blog'))
  .filter((p) => (p.data.postLang || 'en') === currentLocale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead title={t('site.title')} description={t('site.description')} locale={currentLocale} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--color-paper)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--color-ink)] focus:shadow-lg focus:outline-none">
      {currentLocale === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}
    </a>
    <Header locale={currentLocale} />
    <main id="main-content">
      <!-- Hero: full-bleed -->
      <div class="bg-[var(--color-paper-light)]">
        <div class="section-inner py-20 text-center">
          <p class="post-meta mb-3">{currentLocale === 'en' ? 'Vol. I · 2026' : '第一卷 · 2026'}</p>
          <h1 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl">
            {t('site.title')}
          </h1>
          <p class="mx-auto max-w-md text-base leading-relaxed text-[var(--color-ink-muted)]">
            {t('site.description')}
          </p>
        </div>
      </div>

      <!-- Post list -->
      <div class="section-inner">
        <hr class="mb-14" />

        {posts.length > 0 ? (
          <div class="space-y-10">
            {posts.map((post, i) => (
              <article>
                <a
                  href={new URL(`/${currentLocale}/blog/${getSlug(post)}/`, Astro.site).pathname}
                  class="group flex items-start gap-5 no-underline md:gap-8"
                >
                  <span class="hidden font-serif text-3xl font-bold text-[var(--color-ink-muted)] md:block md:w-12 md:shrink-0">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="post-meta mb-2">
                      <FormattedDate date={post.data.pubDate} locale={currentLocale} />
                      {post.data.category && (
                        <span class="ml-3 text-[var(--color-ink-muted)]">· {post.data.category}</span>
                      )}
                      {post.data.difficulty && (
                        <span class="ml-2 text-[var(--color-ink-faint)]">[{post.data.difficulty}]</span>
                      )}
                      {post.data.timeToRead && (
                        <span class="ml-2 text-[var(--color-ink-faint)]">· {post.data.timeToRead} {t('blog.minRead')}</span>
                      )}
                    </div>
                    <h2 class="mb-2 font-serif text-xl font-bold leading-snug text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-accent-light)]">
                      {post.data.title}
                    </h2>
<p class="text-sm leading-relaxed text-[var(--color-ink-muted)]">
  {post.data.description}
</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="py-16 text-center text-[var(--color-ink-faint)]">
            <p class="font-serif text-lg italic">
              {currentLocale === 'en' ? 'Posts coming soon…' : '文章即将上线……'}
            </p>
            <p class="mt-4 text-sm">
              {currentLocale === 'en' ? 'The first issue is in the works.' : '第一期正在筹备中。'}
            </p>
          </div>
        )}
      </div>
    </main>
    <Footer locale={currentLocale} />
  </body>
</html>
