---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { useTranslations, LOCALES } from '../../i18n/ui';
import { getLocaleFromParams, getSlug } from '../../i18n/utils';

export async function getStaticPaths() {
  return Object.keys(LOCALES).map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const currentLocale = getLocaleFromParams(locale);
const t = useTranslations(currentLocale);

const posts = (await getCollection('blog'))
  .filter((p) => (p.data.postLang || 'en') === currentLocale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Compute stats from real data
const categories = new Set(posts.filter(p => p.data.category).map(p => p.data.category!.toLowerCase().replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())));
const totalReadTime = posts.reduce((sum, p) => sum + (p.data.timeToRead || 0), 0);
const avgReadTime = posts.length > 0 ? Math.round(totalReadTime / posts.length) : 0;
const difficulties = new Set(posts.filter(p => p.data.difficulty).map(p => p.data.difficulty!.toLowerCase().replace(/\b\w/g, c => c.toUpperCase())));

const stats = [
  { value: String(posts.length), label: currentLocale === 'zh-CN' ? '篇文章' : 'Articles' },
  { value: String(categories.size), label: currentLocale === 'zh-CN' ? '分类' : 'Categories' },
  { value: `~${avgReadTime}`, label: currentLocale === 'zh-CN' ? '分钟均读' : 'Avg Read' },
  { value: String(difficulties.size), label: currentLocale === 'zh-CN' ? '难度等级' : 'Levels' },
];

// Category pill class helper
function categoryPillClass(cat: string | undefined): string {
  if (!cat) return 'category-pill-default';
  const c = cat.toLowerCase();
  if (c === 'ai-tools') return 'category-pill-ai-tools';
  if (c === 'guide') return 'category-pill-guide';
  if (c === 'review') return 'category-pill-review';
  return 'category-pill-default';
}

function categoryLabel(cat: string | undefined): string {
  if (!cat) return currentLocale === 'zh-CN' ? '未分类' : 'Uncategorized';
  return cat.toLowerCase().replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead title={t('site.title')} description={t('site.description')} locale={currentLocale} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--bg-card)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--text-body)] focus:shadow-lg focus:outline-none">
      {currentLocale === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}
    </a>
    <Header locale={currentLocale} />
    <main id="main-content">

      <!-- ═══ HERO ═══ -->
      <section class="section-inner">
        <div class="mx-auto max-w-[960px] text-center">
          <p class="post-meta mb-4">
            {currentLocale === 'en' ? 'Vol. I · 2026' : '第一卷 · 2026'}
          </p>
          <h1 class="hero-heading mb-5">
            {t('site.title')}
          </h1>
          <p class="mx-auto mb-8 max-w-2xl text-base leading-relaxed text-[var(--text-muted)]">
            {currentLocale === 'en' ? 'Every open-source project deserves a proper setup — deep dive installation guides, comparisons & real-world troubleshooting' : '每个开源项目都值得被认真装一遍 — 深度安装教程、横向对比与真实踩坑记录'}
          </p>

          <!-- Stats row -->
          <div class="hero-stats justify-center">
            {stats.map((s) => (
              <div class="hero-stat">
                <span class="hero-stat-value">{s.value}</span>
                <span class="hero-stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══ ALL POSTS ═══ -->
      <section class="section-inner pt-0">
        <div class="mx-auto" style="max-width: 960px">
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-[var(--text-body)]">
              {currentLocale === 'zh-CN' ? '文章' : 'Articles'}
            </h2>
            {posts.length > 0 && (
              <a href={`/${currentLocale}/blog/`} class="text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] hover:text-[var(--color-accent-ui)] no-underline">
                {currentLocale === 'zh-CN' ? '查看全部 →' : 'View all →'}
              </a>
            )}
          </div>

          {posts.length > 0 ? (
            <div class="flex flex-col gap-3">
              {posts.map((post, i) => (
                <a
                  href={new URL(`/${currentLocale}/blog/${getSlug(post)}/`, Astro.site).pathname}
                  class="article-card no-underline"
                >
                  <span class="article-card-number">{String(i + 1).padStart(2, '0')}</span>
                  <div class="article-card-content">
                    <div class="mb-1 flex flex-wrap items-center gap-2">
                      <span class="post-meta text-[10px]">
                        <FormattedDate date={post.data.pubDate} locale={currentLocale} />
                      </span>
                      {post.data.category && (
                        <span class={`${categoryPillClass(post.data.category)} article-card-category`}>
                          {categoryLabel(post.data.category)}
                        </span>
                      )}
                      {post.data.difficulty && (
                        <span class="text-[10px] uppercase tracking-wider text-[var(--text-faint)]">[{post.data.difficulty}]</span>
                      )}
                      {post.data.timeToRead && (
                        <span class="text-[10px] text-[var(--text-faint)]">· {post.data.timeToRead} {t('blog.minRead')}</span>
                      )}
                    </div>
                    <h3 class="text-base font-semibold leading-snug text-[var(--text-heading)] truncate">
                      {post.data.title}
                    </h3>
                    <p class="mt-1 text-sm leading-relaxed text-[var(--text-muted)] line-clamp-2">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="py-16 text-center text-[var(--text-faint)]">
              <p class="font-serif text-lg italic">
                {currentLocale === 'en' ? 'Posts coming soon…' : '文章即将上线……'}
              </p>
              <p class="mt-2 text-sm">
                {currentLocale === 'en' ? 'The first issue is in the works.' : '第一期正在筹备中。'}
              </p>
            </div>
          )}
        </div>
      </section>

    </main>
    <Footer locale={currentLocale} />
  </body>
</html>
