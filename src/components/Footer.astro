---
const today = new Date();
import { SITE_TITLE } from '../consts';
---

<footer class="border-t border-[var(--color-border)] py-12 text-center">
  <div class="mx-auto max-w-md px-6">
    <p class="mb-1 font-serif text-lg font-bold text-[var(--color-ink)]">{SITE_TITLE}</p>
    <p class="text-sm italic text-[var(--color-ink-light)]">每个开源项目都值得被认真装一遍</p>
    <div class="mt-6 text-xs uppercase tracking-widest text-[var(--color-ink-muted)]">
      &copy; {today.getFullYear()} · Vol. I · Published with Astro
    </div>
  </div>
</footer>
