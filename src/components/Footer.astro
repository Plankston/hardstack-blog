---
const today = new Date();
import { SITE_TITLE } from '../consts';
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-paper)] py-12 text-center text-sm text-[var(--color-ink-light)]">
  <div class="mx-auto max-w-lg px-6">
    <p class="mb-2 font-serif text-base font-bold text-[var(--color-ink)]">{SITE_TITLE}</p>
    <p class="mb-4 italic">每个开源项目都值得被认真装一遍</p>
    <p>&copy; {today.getFullYear()} HardStack. All rights reserved.</p>
  </div>
</footer>
