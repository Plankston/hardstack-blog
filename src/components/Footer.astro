---
import { useTranslations, type Locale } from '../i18n/ui';
import { getLocalePath } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const currentLocale = locale as Locale;
const t = useTranslations(currentLocale);
const today = new Date();
---

<footer class="footer-v2">
  <div class="footer-v2-inner">
    <!-- About -->
    <div>
      <div class="footer-v2-brand font-['JetBrains_Mono'] font-medium text-[0.95rem]">{t('site.title')}</div>
      <p class="footer-v2-tagline">{t('footer.tagline')}</p>
    </div>

    <!-- Navigation -->
    <div>
      <div class="footer-v2-heading">{t('home.navLabel')}</div>
      <ul class="footer-v2-links">
        <li><a href={getLocalePath(currentLocale, '/')}>{t('home.navHome')}</a></li>
        <li><a href={getLocalePath(currentLocale, '/blog/')}>{t('nav.blog')}</a></li>
        <li><a href={getLocalePath(currentLocale, '/about/')}>{t('nav.about')}</a></li>
      </ul>
    </div>

    <!-- Social / Contact -->
    <div>
      <div class="footer-v2-heading">{t('home.connectLabel')}</div>
      <ul class="footer-v2-links">
        <li><a href="https://github.com/Plankston" target="_blank">GitHub</a></li>
        <li><a href={getLocalePath(currentLocale, '/rss.xml')}>RSS</a></li>
        <li><a href="mailto:meng683185@gmail.com">Email</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-v2-bottom">
    &copy; {today.getFullYear()} {t('home.footerYear')}&nbsp;{t('footer.colophon')}
  </div>
</footer>
