---
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const currentLocale = locale as Locale;
const t = useTranslations(currentLocale);
const today = new Date();
---

<footer class="footer-v2">
  <div class="footer-v2-inner">
    <!-- About -->
    <div>
      <div class="footer-v2-brand">{t('site.title')}</div>
      <p class="footer-v2-tagline">{t('footer.tagline')}</p>
    </div>

    <!-- Navigation -->
    <div>
      <div class="footer-v2-heading">{currentLocale === 'zh-CN' ? '导航' : 'Navigate'}</div>
      <ul class="footer-v2-links">
        <li><a href={`/${currentLocale}/`}>{currentLocale === 'zh-CN' ? '首页' : 'Home'}</a></li>
        <li><a href={`/${currentLocale}/blog/`}>{t('nav.blog')}</a></li>
        <li><a href={`/${currentLocale}/about/`}>{t('nav.about')}</a></li>
      </ul>
    </div>

    <!-- Social / Contact -->
    <div>
      <div class="footer-v2-heading">{currentLocale === 'zh-CN' ? '联系' : 'Connect'}</div>
      <ul class="footer-v2-links">
        <li><a href="https://github.com/Plankston" target="_blank">GitHub</a></li>
        <li><a href={`/${currentLocale === 'zh-CN' ? 'zh-CN' : 'en'}/rss.xml`}>RSS</a></li>
        <li><a href="mailto:meng683185@gmail.com">Email</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-v2-bottom">
    &copy; {today.getFullYear()} {currentLocale === 'en' ? '· Vol. I ·' : '· 第一卷 ·'}&nbsp;{t('footer.colophon')}
  </div>
</footer>
