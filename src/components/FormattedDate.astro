---
interface Props {
	date: Date;
	locale?: string;
}

const { date, locale = 'en-US' } = Astro.props;
const lang = locale === 'zh-CN' ? 'zh-CN' : 'en-US';
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(lang, {
			year: 'numeric',
			month: lang === 'zh-CN' ? 'long' : 'short',
			day: 'numeric',
		})
	}
</time>
