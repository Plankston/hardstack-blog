---
interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;
const placeholder = locale === 'zh-CN' ? '搜索文章...' : 'Search articles...';
const hintText = locale === 'zh-CN' ? '输入关键词搜索...' : 'Type to search...';
const noResultsText = locale === 'zh-CN' ? '未找到结果。' : 'No results found.';
const loadingText = locale === 'zh-CN' ? '搜索中...' : 'Searching...';
const errorText = locale === 'zh-CN' ? '搜索出错，请重试。' : 'Search error, please try again.';
---

<div id="search" class="relative">
  <button
    id="search-toggle"
    class="cursor-pointer border-0 bg-transparent p-1 text-[var(--color-ink-faint)] hover:text-[var(--color-ink)] transition-colors"
    aria-label={locale === 'zh-CN' ? '搜索' : 'Search'}
    type="button"
  >
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
    </svg>
  </button>
</div>

<div id="search-modal" class="fixed inset-0 z-[100] hidden items-start justify-center bg-black/30 pt-[15vh]" role="dialog" aria-modal="true">
  <div class="w-full max-w-lg rounded-lg bg-[var(--color-paper)] p-6 shadow-lg border border-[var(--color-border)]">
    <div class="flex items-center gap-3 border-b border-[var(--color-border)] pb-3">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[var(--color-ink-faint)]">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder={placeholder}
        class="w-full border-0 bg-transparent text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-faint)]"
        autofocus
      />
      <button id="search-close" class="cursor-pointer border-0 bg-transparent text-sm text-[var(--color-ink-faint)] hover:text-[var(--color-ink)]" type="button">ESC</button>
    </div>
    <div id="search-results" class="mt-4 max-h-60 space-y-2 overflow-y-auto">
      <p class="text-sm text-[var(--color-ink-faint)]">{hintText}</p>
    </div>
  </div>
</div>

<script is:inline define:vars={{ hintText, noResultsText, loadingText, errorText }}>
  const toggle = document.getElementById('search-toggle');
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const close = document.getElementById('search-close');

  let pagefind = null;

  async function getPagefind() {
    if (!pagefind) {
      try {
        const module = await import('/pagefind/pagefind.js');
        await module.init();
        pagefind = module;
      } catch (error) {
        console.error('Error loading pagefind:', error);
        results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${errorText}</p>`;
        throw error;
      }
    }
    return pagefind;
  }

  function openSearch() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    input.value = '';
    results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${hintText}</p>`;
    input.focus();
  }

  function closeSearch() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  if (toggle && modal) {
    toggle.addEventListener('click', openSearch);
    close.addEventListener('click', closeSearch);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeSearch(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeSearch();
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
    });

    let debounceTimer;
    input.addEventListener('input', async () => {
      clearTimeout(debounceTimer);
      const term = input.value.trim();
      if (!term) {
        results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${hintText}</p>`;
        return;
      }

      // Show loading state
      results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${loadingText}</p>`;

      debounceTimer = setTimeout(async () => {
        try {
          const pf = await getPagefind();
          if (!pf) {
            results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${errorText}</p>`;
            return;
          }

          const searchResults = await pf.search(term);

          // Validate search results
          if (!searchResults || !Array.isArray(searchResults.results)) {
            results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${noResultsText}</p>`;
            return;
          }

          if (searchResults.results.length === 0) {
            results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${noResultsText}</p>`;
            return;
          }

          // Build results HTML with error handling
          let html = '';
          try {
            for (const r of searchResults.results.slice(0, 10)) {
              try {
                const data = await r.data();
                html += `<a href="${data.url}" class="block rounded p-2 text-sm no-underline hover:bg-[var(--color-code-bg)] transition-colors">
                  <div class="font-medium text-[var(--color-ink)]">${data.meta.title || 'Untitled'}</div>
                  <div class="text-xs text-[var(--color-ink-faint)]">${data.excerpt || ''}</div>
                </a>`;
              } catch (dataError) {
                console.error('Error fetching search result data:', dataError);
                // Skip this result but continue with others
                continue;
              }
            }
          } catch (loopError) {
            console.error('Error processing search results:', loopError);
            results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${errorText}</p>`;
            return;
          }

          results.innerHTML = html;
        } catch (error) {
          console.error('Search error:', error);
          results.innerHTML = `<p class="text-sm text-[var(--color-ink-faint)]">${errorText}</p>`;
        }
      }, 200);
    });
  }
</script>
