---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'> & { locale?: string };

const { href: rawHref, locale = 'en', class: className, ...props } = Astro.props as Props;
const href = rawHref?.toString() || '';
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.replace(/^\/(en|zh-CN)/, '').match(/[^\/]+/g);
const isActive = href === pathname || href.endsWith('/' + (subpath?.[0] || ''));
---

<a
  href={href}
  class:list={[className, { active: isActive }]}
  {...props}
>
  <slot />
</a>

<style>
  a {
    display: inline-block;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.88em;
    transition: color 0.15s;
  }
  a:hover {
    color: var(--text-body);
  }
  a.active {
    color: var(--text-body);
    font-weight: 600;
  }
</style>
