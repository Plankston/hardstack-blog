---
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
import { useTranslations, LOCALES, type Locale } from '../i18n/ui';
import { getLocalePath } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const currentLocale = locale as Locale;
const t = useTranslations(currentLocale);
---

<header class="glass-header sticky top-0 z-50">
  <nav class="mx-auto flex max-w-[1400px] items-center px-8 py-3">
    <a href={getLocalePath(currentLocale, '/')} class="font-['JetBrains_Mono'] text-[0.95rem] font-medium tracking-tight no-underline text-[var(--text-heading)] hover:text-[var(--color-accent-ui)] whitespace-nowrap">
      {t('site.title')}
    </a>
    <div class="flex flex-1 items-center justify-end gap-6">
      <div class="flex items-center gap-5">
        <HeaderLink href={getLocalePath(currentLocale, '/blog')} locale={currentLocale}>{t('nav.blog')}</HeaderLink>
        <HeaderLink href={getLocalePath(currentLocale, '/about')} locale={currentLocale}>{t('nav.about')}</HeaderLink>
      </div>

      <Search locale={currentLocale} />

      <div class="flex items-center gap-2 border-l border-[var(--border-color)] pl-4">
        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          class="flex h-7 w-7 items-center justify-center rounded-md border border-[var(--border-color)] text-[var(--text-muted)] transition-colors hover:text-[var(--text-body)]"
          aria-label="Toggle theme"
        >
          <svg id="theme-icon-paper" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
          <svg id="theme-icon-dark" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </button>

        <!-- Locale switcher: dropdown -->
        <div class="relative" id="locale-switcher">
          <button
            id="locale-toggle"
            class="flex items-center gap-1 rounded-md border border-[var(--border-color)] px-2 py-1 text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] transition-colors hover:text-[var(--text-body)]"
            aria-expanded="false"
            aria-controls="locale-menu"
          >
            {currentLocale === 'en' ? 'EN' : LOCALES[currentLocale]}
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>

          <div
            id="locale-menu"
            role="menu"
            class="absolute right-0 top-full z-50 mt-1 hidden min-w-[110px] rounded-lg border border-[var(--border-color)] bg-[var(--bg-card)] py-1 shadow-lg"
          >
            {Object.entries(LOCALES).map(([code, label]) => {
              const isEn = code === 'en';
              const currentPath = Astro.url.pathname;
              // Remove locale prefix from current path to get the base path
              const basePath = currentPath.replace(/^\/(en|zh-CN)/, '') || '/';
              const newPath = isEn ? basePath : `/${code}${basePath}`;
              return (
                <a
                  href={newPath}
                  role="menuitem"
                  class:list={[
                    'block px-3 py-1.5 text-xs font-medium transition-colors no-underline',
                    code === currentLocale
                      ? 'text-[var(--color-accent-ui)] bg-[var(--bg-header)]'
                      : 'text-[var(--text-muted)] hover:text-[var(--text-body)] hover:bg-[var(--bg-header)]',
                  ]}
                >
                  {LOCALES[code as Locale]}
                </a>
              );
            })}
          </div>
        </div>

        <a href="https://github.com/Plankston/hardstack-blog" target="_blank" class="text-[var(--text-faint)] hover:text-[var(--text-body)] transition-colors" aria-label="GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const iconPaper = document.getElementById('theme-icon-paper');
  const iconDark = document.getElementById('theme-icon-dark');

  function getTheme(): string {
    return localStorage.getItem('theme') || 'paper';
  }

  function applyTheme(theme: string) {
    document.body.dataset.template = theme;
    localStorage.setItem('theme', theme);
    if (iconPaper && iconDark) {
      iconPaper.classList.toggle('hidden', theme !== 'paper');
      iconDark.classList.toggle('hidden', theme !== 'dark');
    }
    // Sync Giscus theme
    const giscusFrame = document.querySelector('iframe.giscus-frame') as HTMLIFrameElement;
    if (giscusFrame) {
      giscusFrame.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: theme === 'dark' ? 'dark' : 'light' } } },
        'https://giscus.app'
      );
    }
  }

  // Apply stored theme immediately
  applyTheme(getTheme());

  themeToggle?.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'paper' : 'dark';
    applyTheme(next);
  });

  // Locale switcher
  const toggle = document.getElementById('locale-toggle');
  const menu = document.getElementById('locale-menu');
  const switcher = document.getElementById('locale-switcher');

  if (toggle && menu) {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isHidden = menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isHidden));
    });

    document.addEventListener('click', (e) => {
      if (switcher && !switcher.contains(e.target)) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
