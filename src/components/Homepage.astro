---
import { getCollection } from 'astro:content';
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import FormattedDate from './FormattedDate.astro';
import { useTranslations, type Locale } from '../i18n/ui';
import { getSlug, categoryPillClass, categoryLabel, getLocalePath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const posts = (await getCollection('blog'))
  .filter((p) => (p.data.postLang || 'en') === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = new Set(posts.filter(p => p.data.category).map(p => p.data.category!.toLowerCase().replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())));
const totalReadTime = posts.reduce((sum, p) => sum + (p.data.timeToRead || 0), 0);
const avgReadTime = posts.length > 0 ? Math.round(totalReadTime / posts.length) : 0;
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead title={t('site.title')} description={t('home.title')} locale={locale} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--bg-card)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--text-body)] focus:shadow-lg focus:outline-none">
      {t('skipToContent')}
    </a>
    <Header locale={locale} />
    <main id="main-content">

      <!-- HERO -->
      <section class="section-inner">
        <div class="hero-grid">
          <div>
            <p class="hero-eyebrow">
              {t('site.title').toLowerCase()} ~/blog
            </p>
            <h1 class="hero-heading mb-5">
              {t('site.title')}
            </h1>
            <p class="mb-8 max-w-[480px] text-[1.05rem] leading-relaxed text-[var(--text-muted)]">
              {t('home.hero')}
            </p>
            <a href="#article-list" class="hero-cta">
              {t('home.readLatest')} →
            </a>
          </div>

          <div>
            <div class="terminal-card">
              <div class="terminal-header">
                <span class="terminal-dot terminal-dot-red"></span>
                <span class="terminal-dot terminal-dot-yellow"></span>
                <span class="terminal-dot terminal-dot-green"></span>
                <span class="terminal-title">{t('site.title').toLowerCase()} — stats</span>
              </div>
              <div class="terminal-body">
                <span class="label">$</span> <span class="highlight">cat</span> blog.stats<br />
                <span class="label">articles:</span> <span class="value">{posts.length}</span><br />
                <span class="label">categories:</span> <span class="value-warm">{categories.size}</span><br />
                <span class="label">avg_read:</span> <span class="value">~{avgReadTime} min</span><br />
                <span class="label">languages:</span> <span class="value-warm">EN, 中文</span><br />
                <span class="label">status:</span> <span class="value">active</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ALL POSTS -->
      <section class="section-inner pt-0" id="article-list">
        <div class="section-header">
          <h2 class="section-title">
            // {t('home.latestArticles')}
          </h2>
          {posts.length > 0 && (
            <a href={getLocalePath(locale, '/blog/')} class="section-link">
              {t('home.viewAll')} →
            </a>
          )}
        </div>

        {posts.length > 0 ? (
          <div class="article-list" id="article-list-items">
            {posts.map((post, i) => (
              <a
                href={new URL(getLocalePath(locale, `/blog/${getSlug(post) || ''}/`), Astro.site).pathname}
                class="article-card reveal"
                style={`transition-delay: ${i * 60}ms; animation-delay: ${i * 60}ms`}
              >
                <span class="article-card-number">{String(i + 1).padStart(2, '0')}</span>
                <div class="article-card-content">
                  <div class="article-card-meta">
                    <span class="article-card-date">
                      <FormattedDate date={post.data.pubDate} locale={locale} />
                    </span>
                    {post.data.category && (
                      <span class={`${categoryPillClass(post.data.category)} article-card-category`}>
                        {categoryLabel(post.data.category)}
                      </span>
                    )}
                    {post.data.difficulty && (
                      <span class="article-card-difficulty">[{post.data.difficulty}]</span>
                    )}
                  </div>
                  <h3 class="article-card-title">
                    {post.data.title}
                  </h3>
                  <p class="article-card-desc">
                    {post.data.description}
                  </p>
                </div>
                <div class="article-card-right">
                  {post.data.timeToRead && (
                    <div class="article-card-readtime">{post.data.timeToRead} min</div>
                  )}
                  <div class="article-card-views" data-slug={getSlug(post)}>
                    <span>-</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="py-16 text-center text-[var(--text-faint)]">
            <p class="font-serif text-lg italic">
              {t('home.emptyTitle')}
            </p>
            <p class="mt-2 text-sm">
              {t('home.emptyDesc')}
            </p>
          </div>
        )}
      </section>

    </main>
    <Footer locale={locale} />
  </body>
</html>

<script>
  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    }
  }, { rootMargin: '40px' });
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  document.addEventListener('DOMContentLoaded', async () => {
    const cards = document.querySelectorAll('.article-card-views');
    const slugs = Array.from(cards).map(el => el.getAttribute('data-slug')).filter(Boolean);

    if (slugs.length === 0) return;

    try {
      const res = await fetch(`/api/views?slugs=${slugs.join(',')}`);
      const { views } = await res.json();

      cards.forEach(el => {
        const slug = el.getAttribute('data-slug');
        const count = views[slug || ''] || 0;
        const countEl = el.querySelector('span');
        if (countEl) countEl.textContent = count.toString();
      });
    } catch (e) {
      console.error('Failed to load views:', e);
    }
  });
</script>
