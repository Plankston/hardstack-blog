---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  difficulty?: string;
  timeToRead?: number;
  locale: string;
  template?: 'paper' | 'clean' | 'dark';
  slug?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  difficulty,
  timeToRead,
  locale,
  template = 'paper',
  slug,
} = Astro.props;
const t = useTranslations(locale);

// Generate JSON-LD structured data for Article schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'HardStack',
    url: 'https://hardstack.org',
  },
  publisher: {
    '@type': 'Organization',
    name: 'HardStack',
    url: 'https://hardstack.org',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://hardstack.org${Astro.url.pathname}`,
  },
  inLanguage: locale === 'zh-CN' ? 'zh-CN' : 'en',
  keywords: [],
};

// Template display names
const templateLabel: Record<string, string> = {
  paper: locale === 'zh-CN' ? '文章' : 'Editorial',
  clean: locale === 'zh-CN' ? '墨水屏' : 'E-Ink',
  dark: locale === 'zh-CN' ? '代码' : 'Code',
};
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      locale={locale} 
      ogImage={slug ? `/og/${slug}.png` : undefined}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body data-template={template}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--bg-card)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--text-body)] focus:shadow-lg focus:outline-none">
      {locale === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}
    </a>
    <Header locale={locale} />
    <main id="main-content">
      <article>
        <!-- Article header -->
        <div style="background:var(--bg-header)">
          <div class="section-inner">
            <header class="mx-auto" style="max-width:var(--prose-max-w)">
              <!-- Post meta -->
              <div class="post-meta mb-3 flex flex-wrap items-center gap-x-2">
                <span>{t('blog.postedOn')} <FormattedDate date={pubDate} locale={locale} /></span>
                {updatedDate && (
                  <span>· {t('blog.updatedOn')} <FormattedDate date={updatedDate} locale={locale} /></span>
                )}
                {category && <span class="inline-flex items-center rounded-full bg-[var(--color-accent-ui)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-accent-ui)]">{category}</span>}
                {difficulty && <span class="text-[var(--text-faint)]">[{difficulty}]</span>}
                {timeToRead && <span>· {timeToRead} {t('blog.minRead')}</span>}
                <!-- Template badge -->
                <span class="ml-auto inline-flex items-center rounded-full border border-[var(--border-color)] px-2.5 py-0.5 text-xs text-[var(--text-faint)]">
                  {templateLabel[template]}
                </span>
              </div>
              <h1 class="font-['Instrument_Serif'] text-3xl leading-tight md:text-4xl" style="font-weight:400">
                {title}
              </h1>
              <p class="mt-4 max-w-2xl text-sm leading-relaxed text-[var(--text-muted)]">
                {description}
              </p>
            </header>
          </div>
        </div>

        <!-- Article body -->
        <div class="section-inner">
          <div class="prose">
            <slot />
          </div>

          <!-- Template metadata footer -->
          <div style="max-width:var(--prose-max-w);margin:2rem auto 0;text-align:center;font-size:0.75rem;color:var(--text-faint)">
            {locale === 'zh-CN'
              ? `阅读模式: ${templateLabel[template]}`
              : `Reading mode: ${templateLabel[template]}`}
          </div>
        </div>
        </article>
        <hr class="comment-divider" />
        <div class="comment-section">
          <Giscus locale={locale} />
        </div>
    </main>
    <Footer locale={locale} />
  </body>
</html>
