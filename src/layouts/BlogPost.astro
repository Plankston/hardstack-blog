---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  difficulty?: string;
  timeToRead?: number;
}

const { title, description, pubDate, updatedDate, category, timeToRead } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        <header class="mb-10">
          <div class="post-meta mb-3">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="ml-2">· Updated <FormattedDate date={updatedDate} /></span>
            )}
            {timeToRead && <span class="ml-2">· {timeToRead} min read</span>}
          </div>
          <h1 class="font-serif text-3xl leading-tight md:text-4xl">{title}</h1>
          <p class="mt-4 max-w-xl text-sm leading-relaxed text-[var(--color-ink-light)]">
            {description}
          </p>
        </header>

        <hr class="mb-10" />

        <div class="prose">
          <slot />
        </div>

        <Giscus />
      </article>
    </main>
    <Footer />
  </body>
</html>
