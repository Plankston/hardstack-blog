---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  difficulty?: string;
  timeToRead?: number;
  locale: string;
  template?: 'paper' | 'clean' | 'dark';
  slug?: string;
  wordCount?: number;
  relatedPosts?: Array<{
    slug: string;
    title: string;
    description: string;
    category?: string;
    difficulty?: string;
    timeToRead?: number;
    date?: Date;
  }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  difficulty,
  timeToRead,
  locale,
  template = 'paper',
  slug,
  wordCount,
  relatedPosts = [],
} = Astro.props;
const t = useTranslations(locale);

// Generate JSON-LD structured data for BlogPosting schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Plankston',
    url: 'https://github.com/Plankston',
  },
  publisher: {
    '@type': 'Organization',
    name: 'HardStack',
    url: 'https://hardstack.org',
    logo: {
      '@type': 'ImageObject',
      url: 'https://hardstack.org/favicon.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://hardstack.org${Astro.url.pathname}`,
  },
  inLanguage: locale === 'zh-CN' ? 'zh-CN' : 'en',
  keywords: category ? [category] : [],
  timeRequired: timeToRead ? `PT${timeToRead}M` : undefined,
  wordCount: wordCount || undefined,
  image: slug ? `https://hardstack.org/og/${slug}.webp` : undefined,
};

// Template display names
const templateLabel: Record<string, string> = {
  paper: locale === 'zh-CN' ? '文章' : 'Editorial',
  clean: locale === 'zh-CN' ? '墨水屏' : 'E-Ink',
  dark: locale === 'zh-CN' ? '代码' : 'Code',
};
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      locale={locale} 
      ogImage={slug ? `/og/${slug}.webp` : undefined}
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: locale === 'zh-CN' ? 'https://hardstack.org/zh-CN/' : 'https://hardstack.org/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: locale === 'zh-CN' ? 'https://hardstack.org/zh-CN/blog/' : 'https://hardstack.org/blog/',
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: title,
        },
      ],
    })} />
  </head>
  <body data-template={template}>
    <div id="reading-progress" class="reading-progress"></div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--bg-card)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--text-body)] focus:shadow-lg focus:outline-none">
      {locale === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}
    </a>
    <Header locale={locale} />
    <main id="main-content">
      <article>
        <!-- Article header -->
        <div style="background:var(--bg-header)">
          <div class="section-inner">
            <header class="mx-auto" style="max-width:var(--prose-max-w)">
              <!-- Post meta -->
              <div class="post-meta mb-3 flex flex-wrap items-center gap-x-2">
                <span>{t('blog.postedOn')} <FormattedDate date={pubDate} locale={locale} /></span>
                {updatedDate && (
                  <span>· {t('blog.updatedOn')} <FormattedDate date={updatedDate} locale={locale} /></span>
                )}
                {category && <span class="inline-flex items-center rounded-full bg-[var(--color-accent-ui)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-accent-ui)]">{category}</span>}
                {difficulty && <span class="text-[var(--text-faint)]">[{difficulty}]</span>}
                {timeToRead && <span>· {timeToRead} {t('blog.minRead')}</span>}
                <!-- Template badge -->
                <span class="ml-auto inline-flex items-center rounded-full border border-[var(--border-color)] px-2.5 py-0.5 text-xs text-[var(--text-faint)]">
                  {templateLabel[template]}
                </span>
              </div>
              <h1 class="font-['Instrument_Serif'] text-3xl leading-tight md:text-4xl" style="font-weight:400">
                {title}
              </h1>
              <p class="mt-4 max-w-2xl text-sm leading-relaxed text-[var(--text-muted)]">
                {description}
              </p>
            </header>
          </div>
        </div>

        <!-- Article body -->
        <div class="section-inner">
          <div class="prose">
            <slot />
          </div>

          <!-- Related posts -->
          {relatedPosts.length > 0 && (
            <div class="related-posts" style="max-width:var(--prose-max-w);margin:3rem auto 0">
              <h3 class="related-posts-title">
                {locale === 'zh-CN' ? '相关文章' : 'Related Articles'}
              </h3>
              <div class="related-posts-grid">
                {relatedPosts.map((rp) => (
                  <a href={locale === 'zh-CN' ? `/zh-CN/blog/${rp.slug}/` : `/blog/${rp.slug}/`} class="related-post-card">
                    <span class="related-post-category">{rp.category || (locale === 'zh-CN' ? '未分类' : 'Uncategorized')}</span>
                    <span class="related-post-title">{rp.title}</span>
                    <span class="related-post-meta">
                      {rp.timeToRead && `${rp.timeToRead} ${locale === 'zh-CN' ? '分钟' : 'min'}`}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Template metadata footer -->
          <div style="max-width:var(--prose-max-w);margin:2rem auto 0;text-align:center;font-size:0.75rem;color:var(--text-faint)">
            {locale === 'zh-CN'
              ? `阅读模式: ${templateLabel[template]}`
              : `Reading mode: ${templateLabel[template]}`}
          </div>
        </div>
        </article>

    </main>
    <Footer locale={locale} />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('pre.astro-code').forEach((pre) => {
          const lang = pre.getAttribute('data-language') || 'text';
          const header = document.createElement('div');
          header.className = 'code-block-header';
          header.innerHTML = `<span class="code-block-lang">${lang}</span><button class="code-block-copy" aria-label="Copy code">Copy</button>`;
          pre.parentNode.insertBefore(header, pre);
          pre.classList.add('code-block-pre');
        });

        document.addEventListener('click', (e) => {
          const btn = e.target.closest('.code-block-copy');
          if (!btn) return;
          const pre = btn.closest('.code-block-wrap')?.querySelector('pre');
          if (!pre) return;
          const text = pre.textContent.replace(/\n$/, '');
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
          });
        });
      });

      // Reading progress bar
      const bar = document.getElementById('reading-progress');
      if (bar) {
        const update = () => {
          const h = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : '0%';
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }
    </script>
  </body>
</html>
