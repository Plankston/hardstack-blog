---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  difficulty?: string;
  timeToRead?: number;
  locale: string;
  template?: 'paper' | 'clean' | 'dark';
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  difficulty,
  timeToRead,
  locale,
  template = 'paper',
} = Astro.props;
const t = useTranslations(locale);

// Template display names for badge
const templateLabel: Record<string, string> = {
  paper: locale === 'zh-CN' ? '纸本' : 'Paper',
  clean: locale === 'zh-CN' ? '极简' : 'Clean',
  dark: locale === 'zh-CN' ? '暗色' : 'Dark',
};
---

<!doctype html>
<html lang={t('site.lang')} dir="ltr">
  <head>
    <BaseHead title={title} description={description} locale={locale} />
  </head>
  <body data-template={template}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded focus:bg-[var(--color-paper)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-[var(--color-ink)] focus:shadow-lg focus:outline-none">
      {locale === 'zh-CN' ? '跳到主要内容' : 'Skip to content'}
    </a>
    <Header locale={locale} />
    <main id="main-content">
      <article>
        <!-- Article header: full-bleed with theme-aware background -->
        <div class="bg-[var(--color-paper-light)]">
          <div class="section-inner">
            <header class="mb-10">
              <!-- Post meta -->
              <div class="post-meta mb-3 flex flex-wrap items-center gap-x-2">
                <span>{t('blog.postedOn')} <FormattedDate date={pubDate} locale={locale} /></span>
                {updatedDate && (
                  <span>· {t('blog.updatedOn')} <FormattedDate date={updatedDate} locale={locale} /></span>
                )}
                {category && <span class="inline-flex items-center rounded bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-medium text-[var(--color-accent)]">{category}</span>}
                {difficulty && <span class="text-[var(--color-ink-faint)]">[{difficulty}]</span>}
                {timeToRead && <span>· {timeToRead} {t('blog.minRead')}</span>}
                <!-- Template badge -->
                {template !== 'paper' && (
                  <span class="ml-auto inline-flex items-center rounded border border-[var(--color-border)] px-2 py-0.5 text-xs text-[var(--color-ink-faint)]">
                    {templateLabel[template]}
                  </span>
                )}
              </div>
              <h1 class="font-serif text-3xl leading-tight md:text-4xl max-w-4xl">{title}</h1>
              <p class="mt-4 max-w-2xl text-sm leading-relaxed text-[var(--color-ink-muted)]">
                {description}
              </p>
            </header>
          </div>
        </div>

        <!-- Article body: constrained prose with template-defined width -->
        <div class="section-inner">
          <hr class="mt-0 mb-10" />

          <div class="prose">
            <slot />
          </div>

          <!-- Template metadata footer -->
          <div style="max-width:var(--prose-max-w);margin:2rem auto 0;text-align:center;font-size:0.75rem;color:var(--text-faint)">
            {locale === 'zh-CN'
              ? `阅读模式: ${templateLabel[template]}`
              : `Reading mode: ${templateLabel[template]}`}
          </div>

          <div style="max-width:var(--prose-max-w);margin:0 auto">
            <Giscus locale={locale} />
          </div>
        </div>
      </article>
    </main>
    <Footer locale={locale} />
  </body>
</html>
