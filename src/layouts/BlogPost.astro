---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  difficulty?: string;
  timeToRead?: number;
  locale: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  difficulty,
  timeToRead,
  locale,
} = Astro.props;
const t = useTranslations(locale);
---

<!doctype html>
<html lang={t('site.lang')}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <article>
        <!-- Article header: full-bleed with distinct background -->
        <div class="bg-[var(--color-paper-light)]">
          <div class="section-inner">
            <header class="mb-10">
              <div class="post-meta mb-3">
                {t('blog.postedOn')} <FormattedDate date={pubDate} />
                {updatedDate && (
                  <span class="ml-2">· {t('blog.updatedOn')} <FormattedDate date={updatedDate} /></span>
                )}
                {timeToRead && <span class="ml-2">· {timeToRead} {t('blog.minRead')}</span>}
              </div>
              <h1 class="font-serif text-3xl leading-tight md:text-4xl">{title}</h1>
              <p class="mt-4 max-w-xl text-sm leading-relaxed text-[var(--color-ink-muted)]">
                {description}
              </p>
            </header>
          </div>
        </div>

        <!-- Article body: constrained prose -->
        <div class="section-inner">
          <hr class="mt-0 mb-10" />

          <div class="prose">
            <slot />
          </div>

          <Giscus locale={locale} />
        </div>
      </article>
    </main>
    <Footer locale={locale} />
  </body>
</html>
